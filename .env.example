# MailPilot Environment Configuration
# Copy this file to .env and fill in your values

# Server
PORT=3000
NODE_ENV=production

# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Tracking (set to your deployed URL in production)
TRACKING_BASE_URL=https://your-deployed-domain.com

# CORS (comma-separated allowed origins, leave empty for same-origin only)
ALLOWED_ORIGINS=

# Admin emails (comma-separated)
ADMIN_EMAILS=admin@yourdomain.com
